---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../content/site.ts';

const title = `Experience | ${siteConfig.name}`;
const description = 'AI Developer at JPMorganChase building agentic systems. A decade of FinTech, solutions engineering, and technical delivery.';

// Experience data
const experiences = [
  {
    role: "AI Developer",
    company: "JPMorganChase",
    duration: "Dec 2025 – Present",
    location: "Philippines (Onsite)",
    type: "current",
    description: "Designing and developing agentic AI systems and agent workflows using in-house libraries built on Google ADK, LangGraph, and LangChain. Applying FinTech domain knowledge to build reliable, production-grade AI solutions within a global financial institution.",
    achievements: [
      "Building multi-agent orchestration workflows using in-house libraries on top of LangGraph and LangChain",
      "Developing agent-based systems with Google ADK for real-world financial workflows",
      "Applying FinTech and payment systems expertise to ensure AI solutions meet compliance and reliability standards",
      "Collaborating with cross-functional engineering teams on agentic system design and deployment"
    ],
    technologies: ["Python", "LangChain", "LangGraph", "Google ADK", "Agentic Systems", "Multi-Agent Orchestration", "FinTech"]
  },
  {
    role: "Technical Solutions Engineer",
    company: "DigitalPH Asia Corporation",
    duration: "Dec 2024 – Dec 2025",
    location: "Makati City, Philippines",
    type: "previous",
    description: "Drove continuous enhancements of Payborit, a major payment aggregator system, while supporting sales and product teams through solution design and client-facing engagements. Applied AI-assisted prototyping using AI Agents and Spec-Driven Development.",
    achievements: [
      "Enhanced Payborit Payment Aggregator with new integrations and improved merchant onboarding workflows",
      "Supported solution design, proposal preparation, and client presentations for enterprise merchants",
      "Applied AI tools and agent workflows to accelerate prototyping and improve productivity",
      "Ensured operational stability of live payment systems through testing, review, and cross-team collaboration"
    ],
    technologies: ["Python", "FastAPI", "Docker", "GCP", "AI Agents", "Spec-Driven Development", "SQL", "API Integration"]
  },
  {
    role: "Senior Technical Business Analyst",
    company: "DigitalPH Asia Corporation",
    duration: "Dec 2020 – Dec 2024",
    location: "Makati City, Philippines",
    type: "previous",
    description: "Bridged the gap between business needs and technical solutions across multiple large-scale system implementations. Progressively took on hands-on development, starting with debugging and automation scripts, then advancing to Python development, API integrations, and containerized deployments on GCP.",
    achievements: [
      "Delivered 10+ projects by leading requirements gathering, system design, and stakeholder management",
      "Built Python automation scripts and handled API integrations to streamline business workflows",
      "Implemented containerized services on GCP for smoother deployment and system reliability",
      "Developed strong foundation in solution architecture, technical documentation, and cross-functional delivery"
    ],
    technologies: ["Python", "SQL", "Docker", "GCP", "Business Analysis", "System Architecture", "Project Management", "API Integration"]
  },
  {
    role: "Technical Business Analyst",
    company: "EightD Corporation",
    duration: "Sep 2019 - Dec 2020",
    location: "Philippines",
    type: "previous",
    description: "Delivered complex systems analysis and process optimization across AFCS implementations. Built expertise in automation solution design, multi-stakeholder coordination, and technical documentation.",
    achievements: [
      "Achieved 99.98% efficiency improvement through process automation (skills now applied to AI workflows)",
      "Mastered complex system integration and multi-stakeholder project management",
      "Built expertise in solution architecture and technical specification development",
      "Developed strong foundation in automation and process optimization"
    ],
    technologies: ["Process Automation", "System Integration", "AFCS Systems", "Solution Design", "Requirements Analysis"]
  },
  {
    role: "SAP SD Technology Consultant",
    company: "DXC Technology",
    duration: "May 2016 - Sep 2019",
    location: "Philippines",
    type: "previous", 
    description: "Delivered 20+ enterprise SAP SD implementations across EMEA and Asia, building deep expertise in system configuration, business process design, and client consultation.",
    achievements: [
      "Delivered 20+ enterprise projects with focus on business process improvement",
      "Developed strong foundation in system configuration and business requirements analysis",
      "Built expertise in client consultation and technical solution presentation",
      "Mastered enterprise software implementation methodologies"
    ],
    technologies: ["Enterprise Systems", "Business Process Design", "SAP SD", "Client Consultation", "System Implementation"]
  }
];

const skills = [
  {
    category: "Business & Technical Analysis",
    skills: ["Requirements Gathering", "Solution Design", "Process Improvement", "Stakeholder Management", "Project Management", "Business Analysis", "Technical Specifications"]
  },
  {
    category: "Programming & Development", 
    skills: ["Python", "SQL", "HTML/CSS", "Bootstrap", "API Integration", "Microservice Architecture", "Database Design", "SAP SD"]
  },
  {
    category: "AI & Agentic Development",
    skills: ["LangChain", "LangGraph", "Google ADK", "RAG Systems", "Agentic Workflows", "Multi-Agent Orchestration", "Prompt Engineering", "OpenAI API", "Scikit-learn"]
  },
  {
    category: "Tools & Technologies",
    skills: ["Jira", "Trello", "Docker", "GCP", "Git", "n8n", "Make", "Zapier", "Payment Systems", "AFCS", "System Integration"]
  },
  {
    category: "Domain Expertise",
    skills: ["FinTech", "Payment Aggregation", "Enterprise Applications", "AFCS Implementation", "Business Process Optimization", "Client Consultation"]
  }
];
---

<MainLayout title={title} description={description}>
  <section class="section">
    <div class="container max-w-4xl">
      <!-- Page Header -->
      <div class="text-center mb-16 animate-in">
        <h1 class="heading-1 text-gray-900 dark:text-white mb-6">
          Experience
        </h1>
        <p class="body-large max-w-3xl mx-auto">
          I'm Jose Fernando Gonzales — AI Developer at JPMorganChase, building agentic systems and LLM-powered workflows. A decade in FinTech and solutions engineering gives my AI work a rare grounding in real business problems and production constraints.
        </p>
      </div>

      <!-- Experience Timeline -->
      <div class="mb-20">
        <h2 class="heading-3 text-gray-900 dark:text-white mb-8 animate-in">
          Professional Timeline
        </h2>
        
        <div class="space-y-8">
          {experiences.map((exp, index) => (
            <div 
              class={`card p-4 sm:p-8 animate-in ${exp.type === 'current' ? 'ring-2 ring-primary-500 ring-opacity-50' : ''}`}
              style={`animation-delay: ${0.1 + index * 0.1}s`}
            >
              <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between mb-4">
                <div class="mb-4 lg:mb-0">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">
                    {exp.role}
                  </h3>
                  <div class="text-lg text-primary-600 dark:text-primary-400 font-medium mb-1">
                    {exp.company}
                  </div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">
                    {exp.location}
                  </div>
                </div>
                
                <div class="flex items-center space-x-2">
                  <span class="text-sm font-medium text-gray-600 dark:text-gray-300">
                    {exp.duration}
                  </span>
                  {exp.type === 'current' && (
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                      Current
                    </span>
                  )}
                </div>
              </div>
              
              <p class="text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
                {exp.description}
              </p>
              
              <div class="mb-6">
                <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">
                  Key Achievements
                </h4>
                <ul class="grid md:grid-cols-2 gap-2">
                  {exp.achievements.map((achievement) => (
                    <li class="flex items-start space-x-2">
                      <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-sm text-gray-600 dark:text-gray-300">
                        {achievement}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
              
              <div>
                <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">
                  Technologies Used
                </h4>
                <div class="flex flex-wrap gap-2">
                  {exp.technologies.map((tech) => (
                    <span class="inline-block px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Skills Section -->
      <div class="mb-20">
        <h2 class="heading-3 text-gray-900 dark:text-white mb-8 animate-in">
          Technical Skills
        </h2>
        
        <div class="grid lg:grid-cols-2 gap-8">
          {skills.map((skillGroup, index) => (
            <div 
              class="card p-6 animate-in"
              style={`animation-delay: ${0.1 + index * 0.05}s`}
            >
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
                {skillGroup.category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {skillGroup.skills.map((skill) => (
                  <span class="inline-block px-3 py-1 text-sm font-medium bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-lg">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Career Transition Section -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8 md:p-12 animate-in">
        <h2 class="heading-3 text-gray-900 dark:text-white mb-6">
          FinTech Depth Meets Agentic AI
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="text-3xl mb-3" role="img" aria-label="Foundation">
              🏗️
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
              Business-First Foundation
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">
              10 years in FinTech, payment systems, and solutions engineering built a deep understanding of how technology must serve real business constraints.
            </p>
          </div>

          <div class="text-center">
            <div class="text-3xl mb-3" role="img" aria-label="Bridge">
              🌉
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
              The AI Advantage
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">
              Enterprise financial context shapes how I design AI — reliable, compliant, and focused on real workflows rather than demos.
            </p>
          </div>

          <div class="text-center">
            <div class="text-3xl mb-3" role="img" aria-label="Innovation">
              🚀
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
              Enterprise AI in Production
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">
              Now building agentic systems at JPMorganChase — multi-agent workflows, LLM orchestration, and production AI at global scale.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="text-center mt-16 animate-in" style="animation-delay: 0.4s">
        <div class="space-y-6">
          <h2 class="heading-3 text-gray-900 dark:text-white">
            Let's Build Something Amazing Together
          </h2>
          <p class="body-large max-w-2xl mx-auto">
            I'm excited to bring my technical experience and AI/ML expertise to help your team deliver impactful solutions.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn btn-primary">
              Get in Touch
            </a>
            <a href="/resume" class="btn btn-secondary">
              View Full Resume
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .animate-in {
    animation: slideIn 0.6s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>